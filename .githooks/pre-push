#!/bin/bash
# PRE-PUSH HOOK: Prevent accidental push of private-local-only branches

while read local_ref local_sha remote_ref remote_sha
do
  # Extract branch name from refs/heads/...
  branch_name=$(git rev-parse --abbrev-ref "$local_ref")

  if [[ "$branch_name" == *"private-local-only"* ]]; then
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    echo "🛑 ERROR: PUSH BLOCKED."
    echo "The branch '$branch_name' is marked as PRIVATE-LOCAL-ONLY."
    echo "This data is not allowed to leave this machine."
    echo "!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"
    exit 1
  fi
done

exit 0
